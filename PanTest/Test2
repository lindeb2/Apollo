FUNCTION GetChoirPannings(n)
    // 1. Define Constants
    SET k = 2
    SET range_limit = 100

    // 2. Handle Edge Case: Single Part
    // We cannot divide by (n-1) if n is 1, so we return center immediately.
    IF n <= 1 THEN
        RETURN [0]
    END IF

    // 3. Calculate Boundaries based on your formula
    // With K=2, this creates a gentler curve than the previous linear logic
    SET maxPan = range_limit * (n - 1) / (n + k)

    // 4. Calculate the distance between each voice
    // Total width is (maxPan * 2), divided by the number of gaps (n - 1)
    SET panStep = (2 * maxPan) / (n - 1)

    // 5. Generate the List
    CREATE LIST results
    SET currentPan = -maxPan  // Start at the negative edge

    FOR i FROM 0 TO (n - 1)
        // Optional: Round to integer if specific hardware requires it
        APPEND Round(currentPan) TO results

        // Move to the next position
        currentPan = currentPan + panStep
    END FOR

    RETURN results
END FUNCTION