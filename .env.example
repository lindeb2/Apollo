# -----------------------------------------------------------------------------
# Routing
# -----------------------------------------------------------------------------
WEB_PORT=3000
API_PORT=8787
DB_PORT=5432
OIDC_MOCK_PORT=9400

PUBLIC_BASE_URL=
# 0.0.0.0 = (listen everywhere)
WEB_LISTEN_HOST=0.0.0.0
# needs to (and should only) be true for local-LAN.
VITE_USE_HTTPS=

# -----------------------------------------------------------------------------
# Backend server
# -----------------------------------------------------------------------------
# Optional absolute host path for media storage.
# - npm backend reads this path directly
# - full Docker bind-mounts this host path into the container at /data/media
# Leave it empty to use the repo default media folder.
# Relative paths are rejected.
MEDIA_HOST_ROOT=
MAX_UPLOAD_BYTES=524288000
RECORD_LOCK_TIMEOUT_SECONDS=30
CHECKPOINT_EVERY_OPS=100
CHECKPOINT_EVERY_SECONDS=30

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=

# -----------------------------------------------------------------------------
# Sessions and bootstrap admin
# -----------------------------------------------------------------------------
JWT_ACCESS_SECRET=change-this-access-secret
JWT_REFRESH_SECRET=change-this-refresh-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=7
COOKIE_SECURE=false

BOOTSTRAP_LOCAL_LOGIN_ENABLED=true
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=changemechangeme

# -----------------------------------------------------------------------------
# OIDC / SSO
# -----------------------------------------------------------------------------
OIDC_ISSUER=
OIDC_PUBLIC_ISSUER=

OIDC_CLIENT_ID=apollo-dev
OIDC_CLIENT_SECRET=apollo-dev-secret
OIDC_SCOPES=openid profile email

# Leave these empty to derive from the current request or PUBLIC_BASE_URL.
OIDC_REDIRECT_URI=
OIDC_POST_LOGOUT_REDIRECT_URI=

# Be careful when setting the following values since npm-backend and docker-backend interpret them diffrently:
# DATABASE_URL, OIDC_ISSUER, PUBLIC_BASE_URL, OIDC_PUBLIC_ISSUER, OIDC_REDIRECT_URI och OIDC_POST_LOGOUT_REDIRECT_URI

# Be careful with the following values:
# - DATABASE_URL and OIDC_ISSUER; if internal, npm-backend and docker-backend interpret them diffrently and only support one at a time.
# - PUBLIC_BASE_URL, OIDC_PUBLIC_ISSUER, OIDC_REDIRECT_URI and OIDC_POST_LOGOUT_REDIRECT_URI; should be public, not docker-internal-adresses.
