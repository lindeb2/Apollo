# -----------------------------------------------------------------------------
# Routing
# -----------------------------------------------------------------------------
WEB_PORT=3000
API_PORT=8787
DB_PORT=5432
OIDC_MOCK_PORT=9400

PUBLIC_BASE_URL=
API_UPSTREAM_ORIGIN=
DATABASE_URL=
OIDC_ISSUER=
OIDC_PUBLIC_ISSUER=

ABSOLUTE_MEDIA_ROOT=
WEB_BIND_HOST=
# needs to (and should only) be true for local-LAN.
VITE_USE_HTTPS=

# -----------------------------------------------------------------------------
# Backend server
# -----------------------------------------------------------------------------
MAX_UPLOAD_BYTES=524288000
RECORD_LOCK_TIMEOUT_SECONDS=30
CHECKPOINT_EVERY_OPS=100
CHECKPOINT_EVERY_SECONDS=30

# -----------------------------------------------------------------------------
# Sessions
# -----------------------------------------------------------------------------
JWT_ACCESS_SECRET=change-this-access-secret
JWT_REFRESH_SECRET=change-this-refresh-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=7
COOKIE_SECURE=false

# -----------------------------------------------------------------------------
# Open ID Connect
# -----------------------------------------------------------------------------
OIDC_CLIENT_ID=apollo-dev
OIDC_CLIENT_SECRET=apollo-dev-secret
OIDC_SCOPES=openid profile email
OIDC_FIRST_ADMIN_CLAIM=

# Leave these empty to derive from the current request or PUBLIC_BASE_URL.
OIDC_REDIRECT_URI=
OIDC_POST_LOGOUT_REDIRECT_URI=

# Examples:
# - local mock gate: OIDC_FIRST_ADMIN_CLAIM=email=alice@example.com
# - provider permissions gate:
#   OIDC_SCOPES=openid profile email permissions
#   OIDC_FIRST_ADMIN_CLAIM=permissions.id=nyckeln-under-dormattan
#
# Be careful with the following values:
# - DATABASE_URL and OIDC_ISSUER; if internal, npm-backend and docker-backend interpret them diffrently and only one at a time can be supported.
# - API_UPSTREAM_ORIGIN; should be the internal backend URL that the frontend proxy can reach in your runtime environment.
# - PUBLIC_BASE_URL, OIDC_PUBLIC_ISSUER, OIDC_REDIRECT_URI and OIDC_POST_LOGOUT_REDIRECT_URI; should be public, not docker-internal-adresses.
