# Apollo env example
#
# Read this file top to bottom once. In day-to-day local dev you usually only
# need to think about:
# - APP_ORIGIN
# - VITE_USE_HTTPS
# - OIDC_ENABLED
#
# If CORS_ORIGIN / OIDC_REDIRECT_URI / OIDC_POST_LOGOUT_REDIRECT_URI are left
# empty, the backend derives them from APP_ORIGIN.

# -----------------------------------------------------------------------------
# App URL and web port
# -----------------------------------------------------------------------------
# The URL users open in the browser.
# Examples:
# - local HTTP:  http://localhost:3000
# - local HTTPS: https://localhost:3000
# - LAN HTTPS:   https://192.168.1.186:3000
APP_ORIGIN=https://localhost:3000

# -----------------------------------------------------------------------------
# Routing
# -----------------------------------------------------------------------------
WEB_PORT=3000
API_PORT=8787
DB_PORT=5432

# 0.0.0.0 = (listen everywhere)
WEB_LISTEN_HOST=0.0.0.0

# HTTPS is needed for local-LAN.
VITE_USE_HTTPS=true

# -----------------------------------------------------------------------------
# Backend server
# -----------------------------------------------------------------------------
MAX_UPLOAD_BYTES=524288000
RECORD_LOCK_TIMEOUT_SECONDS=30
CHECKPOINT_EVERY_OPS=100
CHECKPOINT_EVERY_SECONDS=30

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DB_PROTOCOL=postgres
DB_USER=apollo
DB_PASSWORD=apollo
DB_NAME=apollo

# Overrides the settings above
DATABASE_URL=

# -----------------------------------------------------------------------------
# Sessions and bootstrap admin
# -----------------------------------------------------------------------------
JWT_ACCESS_SECRET=change-this-access-secret
JWT_REFRESH_SECRET=change-this-refresh-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=7
COOKIE_SECURE=false

DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=changemechangeme
BOOTSTRAP_LOCAL_LOGIN_ENABLED=true

# -----------------------------------------------------------------------------
# OIDC / SSO
# -----------------------------------------------------------------------------
OIDC_ENABLED=false

# Internal issuer URLs:
# - OIDC_ISSUER_LOCAL is used by npm backend runs
# - OIDC_ISSUER_DOCKER is used by Docker backend runs
OIDC_ISSUER=
OIDC_ISSUER_LOCAL=
OIDC_ISSUER_DOCKER=

# Public issuer seen by the browser. Leave empty for local dev so Apollo can
# adapt to localhost vs LAN host automatically.
OIDC_PUBLIC_ISSUER=

OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_SCOPES=openid profile email

# Leave these empty to derive them from APP_ORIGIN automatically.
CORS_ORIGIN=
OIDC_REDIRECT_URI=
OIDC_POST_LOGOUT_REDIRECT_URI=

# Only enable for local mock / local HTTP testing.
OIDC_ALLOW_INSECURE_HTTP=false

# -----------------------------------------------------------------------------
# Local OIDC sandbox example
# -----------------------------------------------------------------------------
# APP_ORIGIN=https://localhost:3000
# VITE_USE_HTTPS=true
# OIDC_ENABLED=true
# OIDC_ISSUER_LOCAL=http://localhost:9400
# OIDC_ISSUER_DOCKER=http://host.docker.internal:9400
# OIDC_PUBLIC_ISSUER=
# OIDC_CLIENT_ID=apollo-dev
# OIDC_CLIENT_SECRET=apollo-dev-secret
# CORS_ORIGIN=
# OIDC_REDIRECT_URI=
# OIDC_POST_LOGOUT_REDIRECT_URI=
# OIDC_ALLOW_INSECURE_HTTP=true
