# Frontend settings
# `npm run dev:https` overrides these to use the local `/api` and `/ws` proxy.
VITE_SERVER_API_BASE=http://localhost:8787
VITE_SERVER_WS_BASE=ws://localhost:8787/ws

# Database settings.
PORT=8787
DB_PROTOCOL=postgres
DB_USER=apollo
DB_PASSWORD=apollo
DB_NAME=apollo
DB_PORT=5432
DB_HOST_LOCAL=localhost
DB_HOST_DOCKER=db

JWT_ACCESS_SECRET=change-this-access-secret
JWT_REFRESH_SECRET=change-this-refresh-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=7
CORS_ORIGIN=http://localhost:3000
MAX_UPLOAD_BYTES=524288000
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=changemechangeme
RECORD_LOCK_TIMEOUT_SECONDS=30
CHECKPOINT_EVERY_OPS=100
CHECKPOINT_EVERY_SECONDS=30
