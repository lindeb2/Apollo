# Frontend settings for `npm run dev:web`.
WEB_RUNTIME_MODE=dev
WEB_PORT=3000
APP_ORIGIN=https://localhost:3000
VITE_USE_HTTPS=true
VITE_DEV_HOST=0.0.0.0
VITE_SSL_KEY_PATH=certs/dev.key
VITE_SSL_CERT_PATH=certs/dev.crt
VITE_BACKEND_ORIGIN=http://localhost:8787
VITE_BACKEND_ORIGIN_DOCKER=http://api:8787
VITE_SERVER_API_BASE=/api
VITE_SERVER_WS_BASE=/ws

# Database settings.
PORT=8787
DB_PROTOCOL=postgres
DB_USER=apollo
DB_PASSWORD=apollo
DB_NAME=apollo
DB_PORT=5432
DB_HOST_LOCAL=localhost
DB_HOST_DOCKER=db

JWT_ACCESS_SECRET=change-this-access-secret
JWT_REFRESH_SECRET=change-this-refresh-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=7
CORS_ORIGIN=
COOKIE_SECURE=false
MAX_UPLOAD_BYTES=524288000
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=changemechangeme
BOOTSTRAP_LOCAL_LOGIN_ENABLED=true
OIDC_ENABLED=false
OIDC_ISSUER=
OIDC_ISSUER_LOCAL=
OIDC_ISSUER_DOCKER=
OIDC_PUBLIC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=
OIDC_SCOPES=openid profile email
OIDC_POST_LOGOUT_REDIRECT_URI=
OIDC_ALLOW_INSECURE_HTTP=false
RECORD_LOCK_TIMEOUT_SECONDS=30
CHECKPOINT_EVERY_OPS=100
CHECKPOINT_EVERY_SECONDS=30

# Local OIDC sandbox example:
# OIDC_ENABLED=true
# OIDC_ISSUER_LOCAL=http://localhost:9400
# OIDC_ISSUER_DOCKER=http://host.docker.internal:9400
# OIDC_PUBLIC_ISSUER=
# OIDC_CLIENT_ID=apollo-dev
# OIDC_CLIENT_SECRET=apollo-dev-secret
# APP_ORIGIN=
# OIDC_ALLOW_INSECURE_HTTP=true
